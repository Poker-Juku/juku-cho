// ---- 累積収支チャート（SVG） ----
function CumChart({ series }) {
  if (series.length === 0) {
    return <div style={{ fontSize: 11, color: C.sub, textAlign: "center", padding: "20px 0" }}>このプレイヤーの記録はまだありません</div>;
  }
  const W = 320, H = 130, PX = 6, PY = 12;
  const vals = [0, ...series.map((s) => s.cum)];
  let min = Math.min(...vals), max = Math.max(...vals);
  if (min === max) { min -= 1; max += 1; }
  const range = max - min;
  const n = series.length;
  const x = (i) => PX + (n === 1 ? (W - 2 * PX) / 2 : (i / (n - 1)) * (W - 2 * PX));
  const y = (v) => PY + (1 - (v - min) / range) * (H - 2 * PY);
  const zeroY = y(0);
  const pts = series.map((s, i) => `${x(i)},${y(s.cum)}`).join(" ");
  const areaPts = `${x(0)},${zeroY} ${pts} ${x(n - 1)},${zeroY}`;
  const last = series[n - 1];

  return (
    <div>
      <svg viewBox={`0 0 ${W} ${H}`} style={{ width: "100%", display: "block" }}>
        <defs>
          <linearGradient id="goldFill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stopColor={C.gold} stopOpacity="0.35" />
            <stop offset="100%" stopColor={C.gold} stopOpacity="0.02" />
          </linearGradient>
        </defs>
        <line x1={PX} y1={zeroY} x2={W - PX} y2={zeroY} stroke={C.line} strokeDasharray="4 4" strokeWidth="1" />
        <polygon points={areaPts} fill="url(#goldFill)" />
        <polyline points={pts} fill="none" stroke={C.gold} strokeWidth="2.2" strokeLinejoin="round" strokeLinecap="round" />
        {series.map((s, i) => (
          <circle key={i} cx={x(i)} cy={y(s.cum)} r={i === n - 1 ? 4 : 2.5}
            fill={i === n - 1 ? C.gold : C.bg} stroke={C.gold} strokeWidth="1.5" />
        ))}
      </svg>
      <div style={{ display: "flex", justifyContent: "space-between", fontSize: 9, color: C.sub, fontVariantNumeric: "tabular-nums", marginTop: 4 }}>
        <span>{fmtDateJP(series[0].date)}</span>
        <span>{fmtDateJP(last.date)}</span>
      </div>
    </div>
  );
}

// ============ 名前編集ページ ============
function PlayersPage({ members, addMember, renameMember, deleteMember, reorderMembers }) {
  const [newName, setNewName] = useState("");
  const [menuFor, setMenuFor] = useState(null);
  const [order, setOrder] = useState(members);
  // drag: { name, startIndex, targetIndex, dy, slotH } | null
  const [drag, setDrag] = useState(null);
  const orderRef = useRef(members);
  const dragCtx = useRef(null); // ドラッグ中の計測データ
  const pressTimer = useRef(null);
  const itemRefs = useRef({});
  const rowApis = useRef({});
  const listRef = useRef(null);
  const scrollRaf = useRef(null);
  const lastPointerY = useRef(0);

  useEffect(() => { setOrder(members); orderRef.current = members; }, [members]);

  const suggested = () => {
    let i = members.length + 1;
    let nm;
    do { nm = `Player ${String(i).padStart(2, "0")}`; i++; } while (members.includes(nm));
    return nm;
  };

  // ---- ドラッグ位置の再計算（指の移動・自動スクロールの両方から呼ぶ） ----
  const updateDrag = () => {
    const ctx = dragCtx.current;
    if (!ctx) return;
    const cont = listRef.current;
    const scrollDelta = cont ? cont.scrollTop - ctx.startScrollTop : 0;
    const dy = (lastPointerY.current - ctx.startPointerY) + scrollDelta;
    const draggedCenter = ctx.centers[ctx.startIndex] + dy;
    let target = ctx.startIndex;
    ctx.centers.forEach((c, i) => {
      if (i < ctx.startIndex && draggedCenter < c) target = Math.min(target, i);
      if (i > ctx.startIndex && draggedCenter > c) target = Math.max(target, i);
    });
    ctx.targetIndex = target;
    setDrag({ name: ctx.name, startIndex: ctx.startIndex, targetIndex: target, dy, slotH: ctx.slotH });
  };

  // ---- 画面端に近づいたら自動スクロール ----
  const autoScrollLoop = () => {
    const ctx = dragCtx.current;
    const cont = listRef.current;
    if (!ctx || !cont) return;
    const rect = cont.getBoundingClientRect();
    const y = lastPointerY.current;
    const EDGE = 70, MAX_SPEED = 14;
    let speed = 0;
    if (y < rect.top + EDGE) speed = -Math.ceil(((rect.top + EDGE - y) / EDGE) * MAX_SPEED);
    else if (y > rect.bottom - EDGE) speed = Math.ceil(((y - (rect.bottom - EDGE)) / EDGE) * MAX_SPEED);
    if (speed !== 0) {
      cont.scrollTop += speed;
      updateDrag();
    }
    scrollRaf.current = requestAnimationFrame(autoScrollLoop);
  };

  // ---- ⋯ボタン：タップでメニュー / 長押しでドラッグ ----
  const handleButtonDown = (e, name) => {
    const el = e.currentTarget;
    try { el.setPointerCapture(e.pointerId); } catch (err) {}
    const startY = e.clientY;
    lastPointerY.current = startY;
    let cancelled = false;

    const startDrag = () => {
      const list = orderRef.current;
      const startIndex = list.indexOf(name);
      const rects = list.map((nm) => itemRefs.current[nm]?.getBoundingClientRect());
      if (!rects[startIndex]) return;
      const centers = rects.map((r) => (r ? r.top + r.height / 2 : 0));
      const slotH = rects[startIndex].height + 8; // 行の高さ + 行間
      dragCtx.current = {
        name, startIndex, targetIndex: startIndex,
        centers, slotH,
        startPointerY: lastPointerY.current,
        startScrollTop: listRef.current ? listRef.current.scrollTop : 0,
      };
      setDrag({ name, startIndex, targetIndex: startIndex, dy: 0, slotH });
      if (navigator.vibrate) navigator.vibrate(15);
      scrollRaf.current = requestAnimationFrame(autoScrollLoop);
    };

    const move = (ev) => {
      lastPointerY.current = ev.clientY;
      if (!dragCtx.current) {
        if (Math.abs(ev.clientY - startY) > 10) { clearTimeout(pressTimer.current); cancelled = true; cleanup(); }
        return;
      }
      ev.preventDefault();
      updateDrag();
    };

    const up = () => {
      clearTimeout(pressTimer.current);
      if (scrollRaf.current) { cancelAnimationFrame(scrollRaf.current); scrollRaf.current = null; }
      const ctx = dragCtx.current;
      if (ctx) {
        if (ctx.targetIndex !== ctx.startIndex) {
          const next = [...orderRef.current];
          next.splice(ctx.startIndex, 1);
          next.splice(ctx.targetIndex, 0, ctx.name);
          orderRef.current = next;
          setOrder(next);
          reorderMembers(next);
        }
        dragCtx.current = null;
        setDrag(null);
      } else if (!cancelled) {
        setMenuFor(name);
      }
      cleanup();
    };

    const cleanup = () => {
      el.removeEventListener("pointermove", move);
      el.removeEventListener("pointerup", up);
      el.removeEventListener("pointercancel", up);
    };
    el.addEventListener("pointermove", move);
    el.addEventListener("pointerup", up);
    el.addEventListener("pointercancel", up);

    pressTimer.current = setTimeout(startDrag, 300);
  };

  // ---- 各行の transform を計算 ----
  const rowStyle = (name, i) => {
    if (!drag) return { transform: "none", transition: "transform .18s ease", zIndex: 1 };
    if (name === drag.name) {
      return { transform: `translateY(${drag.dy}px) scale(1.02)`, transition: "none", zIndex: 10, position: "relative" };
    }
    let offset = 0;
    if (drag.startIndex < drag.targetIndex && i > drag.startIndex && i <= drag.targetIndex) offset = -drag.slotH;
    if (drag.startIndex > drag.targetIndex && i >= drag.targetIndex && i < drag.startIndex) offset = drag.slotH;
    return { transform: `translateY(${offset}px)`, transition: "transform .18s ease", zIndex: 1, position: "relative" };
  };

  const registerApi = (name, api) => { rowApis.current[name] = api; };

  return (
    <div style={{ flex: 1, minHeight: 0, display: "flex", flexDirection: "column", padding: "4px 16px 0" }}>
      <div style={{ fontSize: 11, color: C.sub, textAlign: "center", marginBottom: 14, flexShrink: 0, lineHeight: 1.6 }}>
        名前の変更は過去の記録にも反映されます<br />
        <span style={{ color: C.gold }}>⋯ タップでメニュー ・ 長押しで移動</span>
      </div>

      <div ref={listRef} style={{ flex: 1, minHeight: 0, overflowY: "auto", paddingBottom: 16, overscrollBehavior: "contain" }}>
        {order.map((m, i) => (
          <MemberRow key={m} name={m} index={i}
            innerRef={(el) => { itemRefs.current[m] = el; }}
            dragging={drag?.name === m}
            dragStyle={rowStyle(m, i)}
            onRename={(nn) => renameMember(m, nn)}
            onButtonDown={(e) => handleButtonDown(e, m)}
            register={registerApi} />
        ))}

        {/* 追加 */}
        <div style={{ display: "flex", gap: 8, marginTop: 14 }}>
          <input value={newName} onChange={(e) => setNewName(e.target.value)}
            onKeyDown={(e) => { if (e.key === "Enter") { addMember(newName || suggested()); setNewName(""); } }}
            placeholder={`追加する名前（例: ${suggested()}）`}
            style={{
              flex: 1, minWidth: 0, background: C.surface, border: `1px solid ${C.line}`,
              borderRadius: 10, color: C.text, fontSize: 14, padding: "11px 12px",
            }} />
          <button onClick={() => { addMember(newName || suggested()); setNewName(""); }}
            style={{ background: C.gold, color: C.bg, borderRadius: 10, fontSize: 14, fontWeight: 700, padding: "0 18px" }}>
            追加
          </button>
        </div>
      </div>

      {/* ⋯メニュー（クリア / 削除 の確認） */}
      {menuFor && (
        <div onClick={() => setMenuFor(null)}
          style={{ position: "fixed", inset: 0, background: "rgba(3,10,7,0.65)", zIndex: 70, display: "flex", alignItems: "center", justifyContent: "center", padding: 24 }}>
          <div onClick={(e) => e.stopPropagation()}
            style={{ width: "100%", maxWidth: 320, background: C.surfaceHi, border: `1px solid ${C.gold}`, borderRadius: 16, padding: 20 }}>
            <div style={{ fontSize: 14, fontWeight: 700, marginBottom: 4 }}>{menuFor} をどうしますか？</div>
            <div style={{ fontSize: 11, color: C.sub, marginBottom: 16 }}>クリアは名前を空にして書き直せます。削除は選択リストから外れます（過去の記録は残ります）。</div>
            <button onClick={() => { rowApis.current[menuFor]?.clear(); setMenuFor(null); }}
              style={{ width: "100%", padding: "12px 0", borderRadius: 10, background: C.surface, border: `1px solid ${C.line}`, color: C.text, fontSize: 14, marginBottom: 8 }}>
              名前をクリアして書き直す
            </button>
            <button onClick={() => { deleteMember(menuFor); setMenuFor(null); }}
              style={{ width: "100%", padding: "12px 0", borderRadius: 10, background: "rgba(240,138,138,0.12)", border: `1px solid ${C.minus}`, color: C.minus, fontSize: 14, marginBottom: 8 }}>
              削除する
            </button>
            <button onClick={() => setMenuFor(null)}
              style={{ width: "100%", padding: "12px 0", borderRadius: 10, background: "transparent", color: C.sub, fontSize: 13 }}>
              キャンセル
            </button>
          </div>
        </div>
      )}
    </div>
  );
}

function MemberRow({ name, index, onRename, onButtonDown, dragging, dragStyle, innerRef, register }) {
  const [val, setVal] = useState(name);
  const inputRef = useRef(null);
  useEffect(() => setVal(name), [name]);
  useEffect(() => {
    register(name, { clear: () => { setVal(""); setTimeout(() => inputRef.current?.focus(), 50); } });
  }, [name, register]);
  const commit = () => { if (val.trim() && val !== name) onRename(val); };
  return (
    <div ref={innerRef}
      style={{
        display: "flex", alignItems: "center", gap: 8, marginBottom: 8,
        borderRadius: 12, padding: "3px 4px",
        background: dragging ? C.surfaceHi : "transparent",
        border: `1px solid ${dragging ? C.gold : "transparent"}`,
        boxShadow: dragging ? "0 8px 24px rgba(0,0,0,0.5)" : "none",
        willChange: "transform",
        ...dragStyle,
      }}>
      <span style={{ width: 24, fontSize: 11, color: C.sub, fontVariantNumeric: "tabular-nums", textAlign: "right", flexShrink: 0 }}>
        {String(index + 1).padStart(2, "0")}
      </span>
      <input ref={inputRef} value={val} onChange={(e) => setVal(e.target.value)}
        onBlur={commit}
        onKeyDown={(e) => e.key === "Enter" && e.target.blur()}
        placeholder="名前を入力"
        style={{
          flex: 1, minWidth: 0, background: C.surface, border: `1px solid ${C.line}`,
          borderRadius: 10, color: C.text, fontSize: 15, padding: "11px 12px",
          pointerEvents: dragging ? "none" : "auto",
        }} />
      <button onPointerDown={onButtonDown} aria-label="メニュー（長押しで移動）"
        style={{
          width: 38, height: 38, borderRadius: 19, background: dragging ? C.gold : "transparent",
          border: `1px solid ${dragging ? C.gold : C.line}`, color: dragging ? C.bg : C.sub,
          fontSize: 17, flexShrink: 0, lineHeight: 1,
          touchAction: "none", userSelect: "none", cursor: dragging ? "grabbing" : "pointer",
        }}>
        ⋯
      </button>
    </div>
  );
}

