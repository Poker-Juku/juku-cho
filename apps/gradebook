    <button onClick={() => onPress(label)}
      style={{
        padding: "16px 0", borderRadius: 12,
        background: accent === "dim" ? "#183527" : "#204534",
        color: accent === "dim" ? C.gold : C.text,
        fontSize: 20, fontWeight: 700, fontVariantNumeric: "tabular-nums",
        border: `1px solid ${C.line}`,
      }}>
      {label}
    </button>
  );
}
